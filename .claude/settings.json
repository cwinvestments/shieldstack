{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-notify.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-notify.bat\" ] && command -v cmd.exe &>/dev/null; then cmd.exe /c \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\pre-tool-notify.bat\"; else bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-notify.sh; fi",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"$CLAUDE_TOOL_INPUT\" | grep -q \"git push\" && bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-push.sh || exit 0'",
            "timeout": 60000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"$CLAUDE_TOOL_INPUT\" | grep -q \"git commit\" && bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/post-commit.sh || exit 0'",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-end.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
